# --- Token del bot Telegram ---
# Ottenuto da @BotFather con il comando /newbot.
# Esempio: 1234567890:AAH-abcDEFghiJKLmnoPQRstuVWXyz1234567
TELEGRAM_BOT_TOKEN=8735866190:AAHCA3p1txAk0MZiT2MKgi_cWxIKQKRUZsw

# --- ID della chat di destinazione ---
# Per scoprirlo: dopo aver creato il bot, scrivigli /start su Telegram,
# poi apri nel browser (sostituendo <TOKEN> col token sopra):
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# Cerca "chat":{"id": NUMERO ...} — il NUMERO è il TELEGRAM_CHAT_ID.
TELEGRAM_CHAT_ID=548116096
