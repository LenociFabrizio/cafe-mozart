# ============================================================
#  Bistrout & Café Mozart — Variabili d'ambiente
# ------------------------------------------------------------
#  Copia questo file in ".env" e compila i valori reali.
#  NON committare il file .env su Git (è già in .gitignore).
# ============================================================

# ── Database Neon (PostgreSQL) ────────────────────────────
# Ottienila da: console.neon.tech > progetto > Connection Details
# Seleziona "Pooled connection" per le funzioni serverless.
DATABASE_URL=postgresql://neondb_owner:<password>@<host>-pooler.<region>.aws.neon.tech/neondb?sslmode=require

# ── Password pannello admin ───────────────────────────────
# Sostituisci con una password sicura prima del deploy.
ADMIN_PASSWORD=mozart2024

# ── Notifiche Telegram (opzionale) ───────────────────────
# Lascia vuote per disabilitare le notifiche (modalità simulazione/log).
#
# 1) Crea il bot: @BotFather → /newbot
# 2) Copia il TOKEN qui sotto
# 3) Avvia il bot (scrivi /start nella chat del bot)
# 4) Ottieni il CHAT_ID aprendo nel browser:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Porta locale ──────────────────────────────────────────
# Ignorata su Vercel (assegna automaticamente la porta).
PORT=3000
